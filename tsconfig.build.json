{
  "extends": "./tsconfig.app.json",
  "compilerOptions": {
    "baseUrl": ".",
    "paths": {
      "@/*": ["src/*"]
    },
    "noEmit": false,
    "emitDeclarationOnly": true,
    "declaration": true,
    "declarationMap": false,
    "outDir": "./dist",
    "rootDir": "./src"
  },
  "include": [
    "src/index.ts",
    "src/components/**/*.ts",
    "src/ui/**/*.ts",
    "src/ui/**/*.tsx"
  ],
  "exclude": [
    "src/main.tsx",
    "src/App.tsx",
    "src/contexts/**",
    "src/icons/**"
  ]
}
