{
  "name": "@themeshift/ui",
  "version": "0.1.12",
  "description": "ThemeShift UI makes creating your own theme-aware components easy as pie 🥧",
  "license": "MIT",
  "type": "module",
  "publishConfig": {
    "access": "public"
  },
  "files": [
    "dist",
    "theme-contract.json"
  ],
  "sideEffects": [
    "**/*.css"
  ],
  "exports": {
    "./components/Button": {
      "types": "./dist/components/Button/index.d.ts",
      "import": "./dist/components/Button/index.js"
    },
    "./components/Heading": {
      "types": "./dist/components/Heading/index.d.ts",
      "import": "./dist/components/Heading/index.js"
    },
    "./components/Navbar": {
      "types": "./dist/components/Navbar/index.d.ts",
      "import": "./dist/components/Navbar/index.js"
    },
    "./components/Responsive": {
      "types": "./dist/components/Responsive/index.d.ts",
      "import": "./dist/components/Responsive/index.js"
    },
    "./contexts": {
      "types": "./dist/contexts/index.d.ts",
      "import": "./dist/contexts/index.js"
    },
    "./css/base.css": "./dist/css/base.css",
    "./css/tokens.css": "./dist/css/tokens.css",
    "./package.json": "./package.json",
    "./theme-contract.json": "./theme-contract.json",
    "./tokens/*": "./dist/tokens/*"
  },
  "scripts": {
    "dev": "vite",
    "build:app": "vite build",
    "build:components": "node scripts/build.mjs",
    "make:component": "node scripts/maker/index.mjs component",
    "make:icon": "node scripts/maker/index.mjs icon",
    "make:tokens": "node scripts/maker/index.mjs tokens",
    "test": "vitest run --config vitest.config.ts",
    "test:watch": "vitest --config vitest.config.ts",
    "test:coverage": "vitest run --coverage --config vitest.config.ts",
    "lint": "eslint .",
    "preview": "vite preview",
    "storybook": "storybook dev -p 6006",
    "build-storybook": "storybook build"
  },
  "dependencies": {
    "@fontsource-variable/noto-sans": "^5.2.10",
    "classnames": "^2.5.1"
  },
  "peerDependencies": {
    "react": "^19.2.4",
    "react-dom": "^19.2.4"
  },
  "devDependencies": {
    "@chromatic-com/storybook": "^5.1.1",
    "@eslint/js": "^9.39.4",
    "@storybook/addon-a11y": "^10.3.3",
    "@storybook/addon-docs": "^10.3.3",
    "@storybook/addon-vitest": "^10.3.3",
    "@storybook/react-vite": "^10.3.3",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@testing-library/user-event": "^14.6.1",
    "@themeshift/vite-plugin-themeshift": "^0.3.11",
    "@types/jest-axe": "^3.5.9",
    "@types/node": "^24.12.0",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.1",
    "@vitest/browser-playwright": "^4.1.2",
    "@vitest/coverage-v8": "^4.1.2",
    "eslint": "^9.39.4",
    "eslint-plugin-react-hooks": "^7.0.1",
    "eslint-plugin-react-refresh": "^0.5.2",
    "eslint-plugin-storybook": "^10.3.3",
    "globals": "^17.4.0",
    "jest-axe": "^10.0.0",
    "jsdom": "^29.0.1",
    "playwright": "^1.58.2",
    "prettier": "3.8.1",
    "prompts": "^2.4.2",
    "react": "^19.2.4",
    "react-dom": "^19.2.4",
    "sass": "^1.98.0",
    "storybook": "^10.3.3",
    "style-dictionary": "^5.4.0",
    "typescript": "~5.9.3",
    "typescript-eslint": "^8.57.0",
    "vite": "^8.0.1",
    "vitest": "^4.1.2"
  }
}
